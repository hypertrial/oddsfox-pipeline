# OddsFox v0.1.x local environment.
# Copy to `.env` for local overrides. This release is WC2026-only.

DUCKDB_NAME=oddsfox.duckdb
# DUCKDB_PATH=/absolute/path/to/oddsfox.duckdb
# DBT_PROFILES_DIR=/absolute/path/to/dbt/profiles

# Live API pacing.
MARKETS_REQUESTS_PER_SECOND=10
ODDS_REQUESTS_PER_SECOND=40
HTTP_CONNECT_TIMEOUT_SECONDS=5
HTTP_READ_TIMEOUT_SECONDS=60

# Optional WC2026 scope-discovery overrides. Leave unset for the bundled preset.
# WC2026_POLYMARKET_SCOPE_EVENT_SLUGS=2026-fifa-world-cup-winner
# WC2026_POLYMARKET_SCOPE_EVENT_SLUG_PREFIXES=2026-fifa-world-cup
# WC2026_POLYMARKET_SCOPE_EVENT_TAGS=2026-fifa-world-cup,fifa-world-cup,world-cup
# WC2026_POLYMARKET_SCOPE_REGISTRY_MAX_EVENT_PAGES=
# WC2026_POLYMARKET_SCOPE_KEYSET_CLOSED=false
# WC2026_POLYMARKET_SCOPE_KEYSET_VOLUME_MIN=10000
# WC2026_POLYMARKET_SCOPE_KEYSET_RELATED_TAGS=true
# WC2026_POLYMARKET_SCOPE_TAG_DISCOVERY=true
# WC2026_POLYMARKET_SCOPE_TAG_CLOSURE_ROUNDS=2
# WC2026_POLYMARKET_SCOPE_TAG_CRAWL_MAX=100
# WC2026_POLYMARKET_SCOPE_TAG_DISCOVERY_KEYWORDS=world cup,world-cup,fifa,world-cup-2026,fifa-world-cup,wc-2026,world-cup-qualifier,world-cup-qualifiers
# WC2026_POLYMARKET_SCOPE_TAG_CLOSURE_KEYWORD_GATE=true
# WC2026_POLYMARKET_SCOPE_TAG_CRAWL_DENYLIST=sports,soccer,football,politics,pop-culture,crypto,business,economy,world,games

# Schedules are opt-in. Leave disabled in local dev and CI unless intentionally running live ingestion.
WC2026_POLYMARKET_MINUTELY_ODDS_SCHEDULE_ENABLED=false
WC2026_POLYMARKET_MINUTELY_ODDS_LIVE_SCHEDULE_ENABLED=false
WC2026_POLYMARKET_HOURLY_ODDS_SCHEDULE_ENABLED=false

# Optional CLOB credentials for authenticated live flows.
# CLOB_API_KEY=
# CLOB_API_SECRET=
# CLOB_API_PASSPHRASE=
