# OddsFox v0.1.x local environment.
# Copy to `.env` for local overrides.

DUCKDB_NAME=oddsfox.duckdb
# DUCKDB_PATH takes precedence over DUCKDB_NAME. Use an SSD path for hosted runs.
# DUCKDB_PATH=/Volumes/Mac SSD/hypertrial_trilemma/hypertrial/OddsFox/.runtime/warehouse/oddsfox.duckdb
# DBT_PROFILES_DIR=/absolute/path/to/dbt/profiles

# Live API pacing.
MARKETS_REQUESTS_PER_SECOND=10
ODDS_REQUESTS_PER_SECOND=40
KALSHI_REQUESTS_PER_SECOND=5
HTTP_CONNECT_TIMEOUT_SECONDS=5
HTTP_READ_TIMEOUT_SECONDS=60

# Optional WC2026 scope-discovery overrides. Leave unset for the bundled preset.
# POLYMARKET_WC2026_SCOPE_EVENT_SLUGS=2026-fifa-world-cup-winner
# POLYMARKET_WC2026_SCOPE_EVENT_SLUG_PREFIXES=2026-fifa-world-cup
# POLYMARKET_WC2026_SCOPE_EVENT_TAGS=2026-fifa-world-cup,fifa-world-cup,world-cup
# POLYMARKET_WC2026_SCOPE_REGISTRY_MAX_EVENT_PAGES=
# POLYMARKET_WC2026_SCOPE_KEYSET_CLOSED=false
# POLYMARKET_WC2026_SCOPE_KEYSET_VOLUME_MIN=5000
# POLYMARKET_WC2026_SCOPE_KEYSET_RELATED_TAGS=true
# POLYMARKET_WC2026_SCOPE_TAG_DISCOVERY=true
# POLYMARKET_WC2026_SCOPE_TAG_CLOSURE_ROUNDS=2
# POLYMARKET_WC2026_SCOPE_TAG_CRAWL_MAX=100
# POLYMARKET_WC2026_SCOPE_TAG_DISCOVERY_KEYWORDS=world cup,world-cup,fifa,world-cup-2026,fifa-world-cup,wc-2026,world-cup-qualifier,world-cup-qualifiers
# POLYMARKET_WC2026_SCOPE_TAG_CLOSURE_KEYWORD_GATE=true
# POLYMARKET_WC2026_SCOPE_TAG_CRAWL_DENYLIST=sports,soccer,football,politics,pop-culture,crypto,business,economy,world,games

# Schedules are opt-in. Leave disabled in local dev and CI unless intentionally running live ingestion.
POLYMARKET_WC2026_HOURLY_ODDS_SCHEDULE_ENABLED=false
POLYMARKET_US_MIDTERMS_2026_HOURLY_ODDS_SCHEDULE_ENABLED=false
KALSHI_WC2026_HOURLY_ODDS_SCHEDULE_ENABLED=false

# Kalshi uses the public trade API only; no API keys required.
# CLOB_API_KEY=
# CLOB_API_SECRET=
# CLOB_API_PASSPHRASE=
