# OddsFox v0.1.0 local environment.
# Copy to `.env` for local overrides. Values below are the selected-scope-only defaults.

DUCKDB_NAME=oddsfox.duckdb
# DUCKDB_PATH=/absolute/path/to/oddsfox.duckdb
# DBT_PROFILES_DIR=/absolute/path/to/dbt/profiles

# Live API pacing.
MARKETS_REQUESTS_PER_SECOND=10
ODDS_REQUESTS_PER_SECOND=40
HTTP_CONNECT_TIMEOUT_SECONDS=5
HTTP_READ_TIMEOUT_SECONDS=60

# Selected Polymarket scopes (CSV). Default preset is wc2026.
# Available presets: wc2026, us-politics, geopolitics, crypto, economy, nba, nfl, champions-league
POLYMARKET_MARKET_SCOPES=wc2026
# Multi-scope example:
# POLYMARKET_MARKET_SCOPES=wc2026,us-politics

# Per-field scope overrides apply to every selected scope when set; prefer seed YAML presets.
# POLYMARKET_SCOPE_EVENT_SLUGS=2026-fifa-world-cup-winner
# POLYMARKET_SCOPE_EVENT_SLUG_PREFIXES=2026-fifa-world-cup
# POLYMARKET_SCOPE_EVENT_TAGS=2026-fifa-world-cup,fifa-world-cup,world-cup
# POLYMARKET_SCOPE_REGISTRY_MAX_EVENT_PAGES=
# POLYMARKET_SCOPE_KEYSET_CLOSED=false
# POLYMARKET_SCOPE_KEYSET_VOLUME_MIN=10000
# POLYMARKET_SCOPE_KEYSET_RELATED_TAGS=true
# POLYMARKET_SCOPE_TAG_DISCOVERY=true
# POLYMARKET_SCOPE_TAG_CLOSURE_ROUNDS=2
# POLYMARKET_SCOPE_TAG_CRAWL_MAX=100
# POLYMARKET_SCOPE_TAG_DISCOVERY_KEYWORDS=world cup,world-cup,fifa,world-cup-2026,fifa-world-cup,wc-2026,world-cup-qualifier,world-cup-qualifiers
# POLYMARKET_SCOPE_TAG_CLOSURE_KEYWORD_GATE=true
# POLYMARKET_SCOPE_TAG_CRAWL_DENYLIST=sports,soccer,football,politics,pop-culture,crypto,business,economy,world,games

# Schedules are opt-in. Leave disabled in local dev and CI unless intentionally running live ingestion.
POLYMARKET_MINUTELY_ODDS_SCHEDULE_ENABLED=false
POLYMARKET_MINUTELY_ODDS_LIVE_SCHEDULE_ENABLED=false

# Optional CLOB credentials for authenticated live flows.
# CLOB_API_KEY=
# CLOB_API_SECRET=
# CLOB_API_PASSPHRASE=
