# Copy to .env and keep this path on the host SSD.
ODDSFOX_DATA_DIR="/Volumes/Mac SSD/hypertrial_trilemma/hypertrial/OddsFox/.runtime"

# Container-internal paths. Leave these as-is unless you also update the compose mounts.
DUCKDB_PATH=/warehouse/oddsfox.duckdb
DAGSTER_HOME=/dagster-home
DLT_DATA_DIR=/dlt

# Vite embeds this into the static dashboard bundle at build time.
VITE_ODDSFOX_LIVE_URL=http://localhost:8787
